# Hanflux AI — environment
# The AI-chat navigator works fully WITHOUT any key (local keyword matching).
# Everything below is OPTIONAL and only enables LLM interpretation of free text.

# Master switch for the optional LLM intent classifier. Default: off.
VITE_ENABLE_LLM_INTENT=false

# SAFE pattern (recommended): point at a serverless route that holds the real
# ANTHROPIC_API_KEY server-side. The client only ever sees this URL.
# VITE_LLM_PROXY_URL=https://your-app.vercel.app/api/intent

# DEMO-ONLY (NOT for production): a VITE_-prefixed key is baked into the client
# bundle and exposed to every visitor. Use the proxy above for real deployments.
# VITE_ANTHROPIC_API_KEY=sk-ant-...
